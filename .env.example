# Database Configuration (PostgreSQL)
# For local development, use your local PostgreSQL settings
# For Vercel production, use your cloud database credentials (Aiven/Neon/Supabase/Vercel Postgres)

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=blog_db

# JWT Secret for Admin Authentication
# Generate a strong random string (32+ characters)
JWT_SECRET=your-secret-key-change-this-to-something-secure

# Node Environment
NODE_ENV=development

# Vercel Production Database Example:
# DB_HOST=your-database.aiven.net
# DB_PORT=12345
# DB_USER=avnadmin
# DB_PASSWORD=your-secure-password
# DB_NAME=defaultdb
# NODE_ENV=production
